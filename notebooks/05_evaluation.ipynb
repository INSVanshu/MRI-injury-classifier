import sys
sys.path.append('..')

import torch
import pandas as pd
import matplotlib.pyplot as plt
from src.evaluate import evaluate_all
from src.utils import get_device

device = get_device()

# Runs inference on all 3 label types and generates all plots
metrics_df = evaluate_all(
    checkpoint_dir = '../models',
    data_dir       = '../data/raw',
    report_dir     = '../reports',
)

# Flag any label where sensitivity < 0.80
# In medical AI this is a critical threshold

SENSITIVITY_THRESHOLD = 0.80

print("Clinical Safety Check")
print("=" * 40)
for label, row in metrics_df.iterrows():
    status = "✅ PASS" if row['sensitivity'] >= SENSITIVITY_THRESHOLD \
             else "❌ FAIL — Risk of missed injuries"
    print(f"{label:12s} sensitivity={row['sensitivity']:.3f}  {status}")

