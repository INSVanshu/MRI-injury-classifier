import sys
sys.path.append('..')

import torch
from src.model import MRNetClassifier, build_model
from src.utils import load_config, set_seed, get_device, count_parameters

config = load_config('../configs/config.yaml')
set_seed(42)
device = get_device()

model = build_model(config, device)
count_parameters(model)

# Quick forward pass test
dummy = torch.randn(2, 3, 224, 224).to(device)
out   = model(dummy)
print(f"Output shape  : {out.shape}")       # (2, 1)
print(f"Output logits : {out}")
print(f"Probabilities : {torch.sigmoid(out)}")

