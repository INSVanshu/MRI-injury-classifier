import sys
sys.path.append('..')

import torch
from src.dataset import MRNetDataset
from src.transforms import val_transforms
from src.gradcam import GradCAM, visualize_gradcam, load_trained_model
from src.utils import get_device, load_config

config = load_config('../configs/config.yaml')
device = get_device()

# Load your trained checkpoint
model = load_trained_model(
    checkpoint_path = '../models/best_acl_sagittal.pth',
    device          = device,
)

# Load validation set — always run Grad-CAM on unseen data
val_dataset = MRNetDataset(
    data_dir   = f"../{config['data']['raw_dir']}",
    split      = 'valid',
    plane      = 'sagittal',
    label_type = 'acl',
    transform  = val_transforms,
)

print(f"Validation samples: {len(val_dataset)}")

# Find indices of correctly predicted positive cases
# These are the most compelling heatmaps to show

from torch.utils.data import DataLoader
import torch

model.eval()
correct_positive_indices = []

for i in range(len(val_dataset)):
    img, label = val_dataset[i]
    with torch.no_grad():
        logit = model(img.unsqueeze(0).to(device))
        prob  = torch.sigmoid(logit).item()
        pred  = 1 if prob >= 0.5 else 0
    if pred == 1 and int(label.item()) == 1:
        correct_positive_indices.append(i)

print(f"Correctly predicted positive cases: "
      f"{len(correct_positive_indices)}")

# Visualize first 4
visualize_gradcam(
    model     = model,
    dataset   = val_dataset,
    device    = device,
    indices   = correct_positive_indices[:4],
    save_path = '../data/gradcam_correct_positives.png',
)

# False negatives are critical in medical AI
# These are injuries the model MISSED

false_negatives = []

for i in range(len(val_dataset)):
    img, label = val_dataset[i]
    with torch.no_grad():
        logit = model(img.unsqueeze(0).to(device))
        prob  = torch.sigmoid(logit).item()
        pred  = 1 if prob >= 0.5 else 0
    if pred == 0 and int(label.item()) == 1:
        false_negatives.append(i)

print(f"False negatives (missed injuries): {len(false_negatives)}")

if false_negatives:
    visualize_gradcam(
        model     = model,
        dataset   = val_dataset,
        device    = device,
        indices   = false_negatives[:4],
        save_path = '../data/gradcam_false_negatives.png',
    )

import matplotlib.pyplot as plt
import numpy as np

# Pick one normal and one injured case side by side
normal_idx  = val_dataset.labels_df[
    val_dataset.labels_df['label'] == 0
].index[0]
injured_idx = val_dataset.labels_df[
    val_dataset.labels_df['label'] == 1
].index[0]

visualize_gradcam(
    model     = model,
    dataset   = val_dataset,
    device    = device,
    indices   = [normal_idx, injured_idx],
    save_path = '../data/gradcam_normal_vs_injured.png',
)

