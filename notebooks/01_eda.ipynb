# MRI Knee Injury Classifier — Exploratory Data Analysis
# Day 2 | Author: Your Name | Dataset: Stanford MRNet

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.gridspec as gridspec
import os
import yaml
from pathlib import Path

# Load config
with open('../configs/config.yaml', 'r') as f:
    config = yaml.safe_load(f)

DATA_DIR = Path(config['data']['raw_dir'])
print("Config loaded ✓")
print(f"Data directory: {DATA_DIR}")
# Load all label CSVs
train_abnormal = pd.read_csv(DATA_DIR / 'labels/train-abnormal.csv',
                              header=None, names=['id', 'abnormal'])
train_acl      = pd.read_csv(DATA_DIR / 'labels/train-acl.csv',
                              header=None, names=['id', 'acl'])
train_meniscus = pd.read_csv(DATA_DIR / 'labels/train-meniscus.csv',
                              header=None, names=['id', 'meniscus'])

# Merge into one dataframe
train_df = train_abnormal \
    .merge(train_acl, on='id') \
    .merge(train_meniscus, on='id')

print(f"Training samples: {len(train_df)}")
print(train_df.head())
fig, axes = plt.subplots(1, 3, figsize=(14, 4))
fig.suptitle('Class Distribution — Training Set', fontsize=14, fontweight='bold')

labels = ['Abnormal', 'ACL Tear (Sprain)', 'Meniscus (Structural)']
cols   = ['abnormal', 'acl', 'meniscus']
colors = ['#4C9BE8', '#E87B4C', '#4CE8A0']

for ax, col, label, color in zip(axes, cols, labels, colors):
    counts = train_df[col].value_counts().sort_index()
    ax.bar(['Negative', 'Positive'], counts.values, color=[color, '#2C2C2C'])
    ax.set_title(label)
    ax.set_ylabel('Count')
    for i, v in enumerate(counts.values):
        ax.text(i, v + 5, str(v), ha='center', fontweight='bold')

plt.tight_layout()
plt.savefig('../data/eda_class_distribution.png', dpi=150, bbox_inches='tight')
plt.show()
print("Class imbalance noted — will use weighted loss during training")
def load_mri(exam_id, plane='sagittal', split='train'):
    path = DATA_DIR / split / plane / f'{exam_id:0>4}.npy'
    return np.load(path)

# Load a sample exam
sample_id = int(train_df.iloc[0]['id'])
vol = load_mri(sample_id, plane='sagittal')

print(f"MRI volume shape: {vol.shape}")
print(f"  → {vol.shape[0]} slices of {vol.shape[1]}×{vol.shape[2]} pixels")
print(f"Pixel value range: [{vol.min():.1f}, {vol.max():.1f}]")

# Plot equally spaced slices
n_display = 8
indices = np.linspace(0, vol.shape[0] - 1, n_display, dtype=int)

fig, axes = plt.subplots(1, n_display, figsize=(20, 3))
fig.suptitle(f'Sagittal MRI — Exam {sample_id} ({vol.shape[0]} slices)', fontsize=12)

for ax, idx in zip(axes, indices):
    ax.imshow(vol[idx], cmap='gray')
    ax.set_title(f'Slice {idx}', fontsize=8)
    ax.axis('off')

plt.tight_layout()
plt.savefig('../data/eda_sample_slices.png', dpi=150, bbox_inches='tight')
plt.show()
fig, axes = plt.subplots(3, 5, figsize=(16, 10))
fig.suptitle('MRI Planes Comparison — Same Exam', fontsize=14, fontweight='bold')

planes = ['axial', 'coronal', 'sagittal']

for row, plane in enumerate(planes):
    vol = load_mri(sample_id, plane=plane)
    mid = vol.shape[0] // 2
    slice_indices = [mid-4, mid-2, mid, mid+2, mid+4]

    for col, idx in enumerate(slice_indices):
        axes[row, col].imshow(vol[idx], cmap='gray')
        if col == 0:
            axes[row, col].set_ylabel(plane.capitalize(), fontsize=11,
                                       fontweight='bold', rotation=90)
        axes[row, col].set_title(f'Slice {idx}', fontsize=8)
        axes[row, col].axis('off')

plt.tight_layout()
plt.savefig('../data/eda_planes_comparison.png', dpi=150, bbox_inches='tight')
plt.show()
