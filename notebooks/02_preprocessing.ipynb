import sys
sys.path.append('..')

import torch
from torch.utils.data import DataLoader
from src.dataset import MRNetDataset
from src.transforms import train_transforms, val_transforms
from src.utils import load_config, set_seed, get_device, visualize_batch

config = load_config('../configs/config.yaml')
set_seed(42)
device = get_device()
dataset = MRNetDataset(
    data_dir=f"../{config['data']['raw_dir']}",
    split='train',
    plane='sagittal',
    label_type='acl',
    transform=val_transforms,
)

image, label = dataset[0]
print(f"Image shape : {image.shape}")   # expect (3, 224, 224)
print(f"Label       : {label.item()}")  # expect 0.0 or 1.0
print(f"Pixel range : [{image.min():.2f}, {image.max():.2f}]")
loader = DataLoader(dataset, batch_size=8, shuffle=True)
images, labels = next(iter(loader))

print(f"Batch shape: {images.shape}")
visualize_batch(images, labels)
print("Computing class weights for imbalance handling...")
weights = dataset.get_class_weights()
print(f"Will pass pos_weight={weights.item():.2f} to BCEWithLogitsLoss")

## Preprocessing Pipeline — Verified ✅

| Step | Method | Reason |
|---|---|---|
| Normalization | Z-score per volume | MRI intensity varies across scanners |
| Slice selection | Max variance slice | Most structurally informative |
| Resize | 224×224 | ResNet50 input requirement |
| Augmentation | Flip, rotate, jitter | Reduce overfitting on small dataset |
| Class weights | neg/pos ratio | Dataset is imbalanced |

